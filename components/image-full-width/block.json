{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 2,
    "name": "acf/image-full-width",
    "title": "Full-width Image",
    "description": "An image that spans the full width of the viewport",
    "category": "theme-blocks",
    "icon": "format-image",
    "keywords": ["image", "full-width", "hero"],
    "acf": {
        "mode": "auto",
        "renderCallback": "Gust\\Components\\ImageFullWidth::renderBlock"
    },
    "supports": {
        "anchor": true,
        "align": ["wide", "full"],
        "color": {
            "text": false,
            "gradients": false,
            "background": false
        }
    }
}