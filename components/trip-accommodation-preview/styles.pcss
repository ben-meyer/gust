.trip-accommodation-preview__summary {
    padding: space(12);
    border: 1px solid var(--color-mid-blue);
}

.trip-accommodation-preview__header {
    display: flex;
    justify-content: space-between;
    gap: space(8);
}

.trip-accommodation-preview__tags {
    display: flex;
    flex-wrap: wrap;
    gap: space(4);
    padding: 0;
    margin: space(6) 0 0;
    list-style: none;
}

.trip-accommodation-preview__gallery {
    display: grid;
    gap: space(6);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: space(8);
}

.trip-accommodation-preview__gallery-item-inner {
    aspect-ratio: 1 / 1;
}

.trip-accommodation-preview__rooms {
    margin-top: space(12);
}
