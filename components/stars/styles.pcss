.stars {
  display: flex;
    gap: 4px;

    .star__filled,
    .star__empty {
        width: 1.5625rem;

        svg {
            width: 100%;
            height: auto;
        }
    }
}

.star__filled,
.star__empty {
    width: 40px;
    height: 40px;

    svg {
        width: 100%;
        height: 100%;
    }
}