.trip-section-nav {
    position: sticky;
    z-index: 20;
    top: 0;
    background-color: var(--color-neutral);
}

.trip-section-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: space(8);
    padding-block: space(8);
}

.trip-section-nav__items {
    display: flex;
    flex-wrap: wrap;
    gap: space(6);
    padding: 0;
    margin: 0;
    list-style: none;
}

.trip-section-nav__actions {
    display: flex;
    gap: space(4);
}
