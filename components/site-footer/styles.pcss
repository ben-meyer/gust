:root {
    --site-footer--margin-top: spaceFluid(24, 32);
}

.site-footer {
    --link--color: var(--color-foreground);
    --link--color-hover: var(--color-foreground);
    --site-footer--images--aspect-ratio: 28 / 13;
    margin-top: var(--site-footer--margin-top, var(--space-layout));
    padding-top: space(24);
    padding-bottom: space(24);

    .site-footer__logo {
        grid-area: logo;
    }
    .site-footer__top-text {
        grid-area: top-text;
    }
    .site-footer__menu-1 {
        grid-area: menu-1;
    }
    .site-footer__right {
        grid-area: right;
    }

    .site-footer__top {
        display: grid;
        grid-column-gap: space(16);
        grid-row-gap: space(24);
        grid-template-areas:
            'top-text'
            'menu-1'
            'right';

        @media (min-width: 400px) {
            grid-template-areas:
                'top-text menu-1'
                'right    menu-1';
            grid-template-columns: 1fr 1fr;
            padding-bottom: space(80);
            padding-top: space(56);
            border-top: var(--base--border);
        }

        @media (min-width: theme('screens.md')) {
            grid-template-areas: 'top-text menu-1 right';
            grid-template-columns: minmax(0, 1fr) minmax(0, 0.75fr) minmax(0, 1.25fr);
            grid-template-rows: 1fr;
        }

        > * {
            @apply margin-trim;
        }
    }

    .site-footer__logo {
        a {
            display: inline-block;
            width: 100%;
            max-width: space(100);

            @media (min-width: theme('screens.md')) {
                max-width: space(120);
            }
        }

        img {
            display: inline-block;
            width: 100%;
        }
    }

    .site-footer__top-text {
        @apply margin-trim;

        p {
            margin-bottom: 0;
        }

        a {
            @apply link--2;
        }

        > * + * {
            margin-top: space(4);
        }
    }

    .site-footer__menu {
        .site-footer__menu__inner {
            @apply list-reset-hard;

            display: grid;
            gap: space(4);
        }

        .menu-list {
            display: grid;
            padding-top: space(12);
            gap: space(12);
        }

        a {
            @apply link--2;
        }
    }

    .menu__heading {
        @apply type-h6;
        text-transform: capitalize;
    }

    .site-footer__right {
        display: flex;
        flex-direction: column;
        align-self: flex-start;
        gap: space(12);
    }

    .site-footer__form {
        width: 100%;

        .wpcf7 {
            width: 100%;
        }

        .wpcf7-form {
            display: flex;
            flex-direction: column;
            gap: space(8);
        }

        label {
            display: block;
        }

        input[type="email"],
        input[type="text"] {
            @apply input;
            width: 100%;
        }

        input[type="submit"] {
            @apply btn;
        }
    }

    .social-icons {
        --grid--column-gap: space(8);

        display: flex;
        flex-flow: row wrap;
        align-items: center;
        margin-top: space(12);
    }

    .site-footer__images {
        --grid--columns: 2;

        width: 100%;
        max-width: 17.5rem;
        justify-content: center;

        @media (min-width: theme('screens.md')) {
            max-width: none;
        }
    }

    .site-footer__image {
        aspect-ratio: var(--site-footer--images--aspect-ratio);
        max-width: 7.5rem;

        @media (min-width: theme('screens.md')) {
            max-width: none;
            width: 7.5rem;
        }

        > * {
            object-fit: contain;
        }
    }

    .site-footer__bottom {
        padding-top: var(--space-base);
        border-top: var(--base--border);

        .site-footer__bottom__inner {
            align-items: center;
            gap: 1.5625rem;
            text-align: center;
        }

        .site-footer__bottom-text {
            @apply margin-trim;

            max-width: 60em;
            text-align: left;
        }
    }

    @media (max-width: 400px) {
        .site-footer__right {
            border-top: var(--base--border);
            padding-top: var(--space-base);
        }
    }
}
