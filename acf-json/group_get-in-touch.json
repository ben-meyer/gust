                    "default_value": "phone",
                    "return_format": "value",
                    "ui": 1,
                    "wrapper": {
                        "width": "20"
                    },
                    "parent_repeater": "field_git_contacts"
                },
                {
                    "key": "field_git_contact_label",
                    "label": "Label",
                    "name": "label",
