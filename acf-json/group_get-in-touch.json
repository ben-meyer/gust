                    "type": "text",
                    "instructions": "Link target (e.g. https://wa.me/..., mailto:..., tel:...). Leave blank for no link.",
                    "required": 0,
                    "placeholder": "https://wa.me/... or mailto:... or tel:...",
                    "wrapper": {
                        "width": "30"
                    },
                    "parent_repeater": "field_git_contacts"
                }
