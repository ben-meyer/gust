                    "required": 1,
                    "wrapper": {
                        "width": "25"
                    },
                    "parent_repeater": "field_git_contacts"
                },
                {
                    "key": "field_git_contact_value",
                    "label": "Value",
                    "name": "value",
                    "type": "text",
