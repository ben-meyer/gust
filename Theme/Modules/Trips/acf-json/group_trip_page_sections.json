{
    "key": "group_trip_page_sections",
    "title": "Trip Page Sections",
    "fields": [
        {
            "key": "field_trip_highlights",
            "label": "Highlights",
            "name": "highlights",
            "type": "repeater",
            "instructions": "Up to 4 highlight cards. Images should work with a central square crop.",
            "required": 0,
            "collapsed": "field_trip_highlights_heading",
            "min": 0,
            "max": 4,
            "layout": "block",
            "button_label": "Add Highlight",
            "sub_fields": [
                {
                    "key": "field_trip_highlights_image",
                    "label": "Image",
                    "name": "image",
                    "type": "image",
                    "required": 0,
                    "return_format": "array",
                    "preview_size": "medium",
                    "library": "all"
                },
                {
                    "key": "field_trip_highlights_heading",
                    "label": "Heading",
                    "name": "heading",
                    "type": "text",
                    "required": 0
                },
                {
                    "key": "field_trip_highlights_description",
                    "label": "Short Description",
                    "name": "description",
                    "type": "textarea",
                    "required": 0,
                    "rows": 3,
                    "new_lines": "br"
                }
            ]
        },
        {
            "key": "field_trip_included_items",
            "label": "Included Items",
            "name": "included_items",
            "type": "repeater",
            "instructions": "Single-line items only.",
            "required": 0,
            "collapsed": "field_trip_included_items_label",
            "layout": "table",
            "button_label": "Add Included Item",
            "sub_fields": [
                {
                    "key": "field_trip_included_items_label",
                    "label": "Item",
                    "name": "label",
                    "type": "text",
                    "required": 0
                }
            ]
        },
        {
            "key": "field_trip_not_included_items",
            "label": "Not Included Items",
            "name": "not_included_items",
            "type": "repeater",
            "instructions": "Single-line items only.",
            "required": 0,
            "collapsed": "field_trip_not_included_items_label",
            "layout": "table",
            "button_label": "Add Not Included Item",
            "sub_fields": [
                {
                    "key": "field_trip_not_included_items_label",
                    "label": "Item",
                    "name": "label",
                    "type": "text",
                    "required": 0
                }
            ]
        },
        {
            "key": "field_trip_start_time",
            "label": "Trip Start Time",
            "name": "trip_start_time",
            "type": "text",
            "instructions": "Displayed below the Getting There heading. E.g. \"Trip begins at 4pm\".",
            "required": 0
        },
        {
            "key": "field_trip_getting_there_stages",
            "label": "Getting There Stages",
            "name": "getting_there_stages",
            "type": "repeater",
            "instructions": "Each stage can contain multiple travel steps.",
            "required": 0,
            "collapsed": "field_trip_getting_there_stage_title",
            "layout": "block",
            "button_label": "Add Stage",
            "sub_fields": [
                {
                    "key": "field_trip_getting_there_stage_title",
                    "label": "Stage Title",
                    "name": "title",
                    "type": "text",
                    "required": 0
                },
                {
                    "key": "field_trip_getting_there_steps",
                    "label": "Steps",
                    "name": "steps",
                    "type": "repeater",
                    "required": 0,
                    "collapsed": "field_trip_getting_there_step_title",
                    "layout": "block",
                    "button_label": "Add Step",
                    "sub_fields": [
                        {
                            "key": "field_trip_getting_there_step_icon",
                            "label": "Icon",
                            "name": "icon",
                            "type": "select",
                            "required": 0,
                            "choices": {
                                "plane": "Plane",
                                "ferry": "Ferry",
                                "car": "Car",
                                "bus": "Bus",
                                "train": "Train",
                                "walk": "Walk"
                            },
                            "return_format": "value",
                            "ui": 1
                        },
                        {
                            "key": "field_trip_getting_there_step_title",
                            "label": "Title",
                            "name": "title",
                            "type": "text",
                            "required": 0
                        },
                        {
                            "key": "field_trip_getting_there_step_description",
                            "label": "Description",
                            "name": "description",
                            "type": "wysiwyg",
                            "required": 0,
                            "tabs": "all",
                            "toolbar": "basic_formatting",
                            "media_upload": 0
                        }
                    ]
                }
            ]
        },
        {
            "key": "field_trip_reviews_embed_code",
            "label": "Reviews Embed Code",
            "name": "reviews_embed_code",
            "type": "textarea",
            "instructions": "HTML embed code for the reviews section.",
            "required": 0,
            "rows": 6,
            "new_lines": ""
        },
        {
            "key": "field_trip_faqs",
            "label": "FAQs",
            "name": "faqs",
            "type": "repeater",
            "instructions": "Shown in the FAQs section using the shared accordion component.",
            "required": 0,
            "collapsed": "field_trip_faq_question",
            "layout": "block",
            "button_label": "Add FAQ",
            "sub_fields": [
                {
                    "key": "field_trip_faq_question",
                    "label": "Question",
                    "name": "question",
                    "type": "text",
                    "required": 0
                },
                {
                    "key": "field_trip_faq_answer",
                    "label": "Answer",
                    "name": "answer",
                    "type": "wysiwyg",
                    "required": 0,
                    "tabs": "all",
                    "toolbar": "basic_formatting",
                    "media_upload": 0
                }
            ]
        },
        {
            "key": "field_trip_related_stories",
            "label": "Related Stories",
            "name": "related_stories",
            "type": "relationship",
            "instructions": "Select up to 2 stories.",
            "required": 0,
            "post_type": ["story"],
            "filters": ["search"],
            "min": 0,
            "max": 2,
            "return_format": "object"
        },
        {
            "key": "field_trip_related_trips",
            "label": "Related Trips",
            "name": "related_trips",
            "type": "relationship",
            "instructions": "Select up to 3 trips.",
            "required": 0,
            "post_type": ["trip"],
            "filters": ["search", "taxonomy"],
            "min": 0,
            "max": 3,
            "return_format": "object"
        }
    ],
    "location": [[
        {
            "param": "post_type",
            "operator": "==",
            "value": "trip"
        }
    ]],
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true
}
