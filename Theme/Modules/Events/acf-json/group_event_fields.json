{
    "key": "group_event_fields",
    "title": "Event Fields",
    "fields": [
        {
            "key": "field_event_dates",
            "label": "Dates",
            "name": "dates",
            "type": "repeater",
            "instructions": "Add one row per departure window.",
            "required": 0,
            "conditional_logic": 0,
            "wrapper": {"width": "", "class": "", "id": ""},
            "layout": "block",
            "button_label": "Add Dates",
            "sub_fields": [
                {
                    "key": "field_event_dates_start_date",
                    "label": "Start Date",
                    "name": "start_date",
                    "type": "date_picker",
                    "required": 1,
                    "conditional_logic": 0,
                    "wrapper": {"width": "25", "class": "", "id": ""},
                    "display_format": "d/m/Y",
                    "return_format": "Y-m-d",
                    "first_day": 1
                },
                {
                    "key": "field_event_dates_end_date",
                    "label": "End Date",
                    "name": "end_date",
                    "type": "date_picker",
                    "required": 1,
                    "conditional_logic": 0,
                    "wrapper": {"width": "25", "class": "", "id": ""},
                    "display_format": "d/m/Y",
                    "return_format": "Y-m-d",
                    "first_day": 1
                },
                {
                    "key": "field_event_dates_price",
                    "label": "Price (GBP)",
                    "name": "price",
                    "type": "number",
                    "required": 0,
                    "conditional_logic": 0,
                    "wrapper": {"width": "25", "class": "", "id": ""},
                    "min": 0,
                    "step": 0.01
                },
                {
                    "key": "field_event_dates_status",
                    "label": "Availability",
                    "name": "status",
                    "type": "select",
                    "required": 0,
                    "conditional_logic": 0,
                    "wrapper": {"width": "25", "class": "", "id": ""},
                    "choices": {
                        "bookable": "Bookable",
                        "sold_out": "Sold Out",
                        "sold_out_private": "Sold Out \u2013 Private Group"
                    },
                    "default_value": "bookable",
                    "allow_null": 0,
                    "multiple": 0,
                    "ui": 1,
                    "return_format": "value"
                },
                {
                    "key": "field_event_dates_booking_url",
                    "label": "Booking URL",
                    "name": "booking_url",
                    "type": "url",
                    "required": 0,
                    "conditional_logic": [[{"field": "field_event_dates_status", "operator": "==", "value": "bookable"}]],
                    "wrapper": {"width": "100", "class": "", "id": ""},
                    "placeholder": "https://"
                }
            ]
        }
    ],
    "location": [[{
        "param": "post_type",
        "operator": "==",
        "value": "event"
    }]],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "hide_on_screen": "",
    "active": true,
    "description": ""
}
